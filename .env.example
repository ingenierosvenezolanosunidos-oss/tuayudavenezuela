# Copy to .env.local and fill in to enable the live Supabase backend.
# Without these, the app runs on bundled demo data (still fully functional).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google reCAPTCHA v3 — get keys at https://www.google.com/recaptcha/admin
# Site key goes here (public, safe to commit the key name but not the value)
VITE_RECAPTCHA_SITE_KEY=
